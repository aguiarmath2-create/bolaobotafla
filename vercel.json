{
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/site/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*",   "destination": "/api/:path*" },
    { "source": "/logo/:path*",  "destination": "/site/logo/:path*" },
    { "source": "/",             "destination": "/site/index.html" }
  ]
}
